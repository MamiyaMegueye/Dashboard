# ============================================================
# SNDE Suivi Temps Réel — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et remplir les credentials.
# Le .env est dans .gitignore — ne jamais le commiter.

# --- Oracle Connection ---
ORACLE_USER=TAPHA
ORACLE_PASSWORD=richatt
ORACLE_HOST=192.168.10.101
ORACLE_PORT=1521
ORACLE_SERVICE=Sigasnde         

# --- Oracle Limites de sécurité ---
ORACLE_QUERY_TIMEOUT_SEC=600
ORACLE_FETCH_BATCH=10000
MAX_ROWS_PER_QUERY=5000000

# --- Filtre métier ---
# 1=Intérieur, 2=Nouakchott, 3=Nouadhibou
ZONE_ID=2
# Centres admin à exclure
STR_ID_EXCLUDE=1,2,63

# --- DuckDB ---
DUCKDB_PATH=./data/snde.duckdb

# --- Pipeline S_RELEVE ---
INITIAL_LOAD_DAYS=30
INCREMENTAL_OVERLAP_HOURS=1
MAX_RELOAD_DAYS=90
MART_WINDOW_DAYS=30

# --- Pipeline CLOTURE_SECTEUR (Suivi Temps Réel) ---
CLOTURE_NB_CYCLES=3
CLOTURE_ALERT_THRESHOLD_PCT=80
CLOTURE_THRESHOLD_LOW_PCT=50
CLOTURE_THRESHOLD_HIGH_PCT=95
CLOTURE_DORMANT_DAYS=5

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000

# --- Logs ---
LOG_LEVEL=INFO
